# ──────────────────────────────────────────────────────────
# Manifold — Environment Configuration
# Copy to .env and override the values you need. Every variable also has a
# built-in default in the compose stacks, so an empty/partial .env still boots.
# ──────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
APP_ENV=production
SECRET_KEY=replace-with-64-char-random-string
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
TIMEZONE=UTC
FRONTEND_URL=http://localhost:3000

# ── First-run bootstrap + auth ───────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///data/manifold.db
DB_POOL_SIZE=3
DB_POOL_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30

# ── Redis / Taskiq ───────────────────────────────────────
REDIS_URL=redis://manifold-redis:6379/0
TASKIQ_RESULT_TTL=3600

# ── Background job schedules (cron, UTC) ─────────────────
SYNC_CRON=0 * * * *
ALARM_EVAL_CRON=*/5 * * * *
RECURRENCE_DETECT_CRON=0 3 * * *
CLEANUP_CRON=0 4 * * *

# ── Data retention (days) ────────────────────────────────
SYNC_RUN_RETENTION_DAYS=90
NOTIFICATION_DELIVERY_RETENTION_DAYS=90
ALARM_EVALUATION_RETENTION_DAYS=30
EVENT_RETENTION_DAYS=365

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── TrueLayer provider ───────────────────────────────────
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=https://localhost:3443/api/v1/providers/truelayer/callback
TRUELAYER_SANDBOX=true

# ── JSON provider ────────────────────────────────────────
JSON_PROVIDER_API_KEY=

# ── System notifier ──────────────────────────────────────
SYSTEM_NOTIFIER_ID=

# ── Email notifier (SMTP) ────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=manifold@example.com
SMTP_USE_TLS=true

# ── Slack notifier ───────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Telegram notifier ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Frontend / Vite ──────────────────────────────────────
VITE_API_BASE_URL=
VITE_DEV_PROXY_TARGET=http://localhost:8000
VITE_ALLOWED_HOSTS=localhost,example.com
