# ──────────────────────────────────────────────────────────
# Manifold — Environment Configuration
# Copy to .env and fill in values before starting
# ──────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────
APP_ENV=development
SECRET_KEY=replace-with-64-char-random-string
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
TIMEZONE=UTC

# ── First-run bootstrap ──────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (user-managed; SQLite by default) ───────────
DATABASE_URL=sqlite+aiosqlite:///data/manifold.db
# DATABASE_URL=postgresql+asyncpg://manifold:password@host:5432/manifold
# DATABASE_URL=mysql+asyncmy://manifold:password@host:3306/manifold

# ── Background job schedules (cron, UTC) ─────────────────
SYNC_CRON=0 * * * *
ALARM_EVAL_CRON=*/5 * * * *
RECURRENCE_DETECT_CRON=0 3 * * *
CLEANUP_CRON=0 4 * * *

# ── Redis (Taskiq broker + distributed locks) ─────────────
REDIS_URL=redis://manifold-redis:6379/0
TASKIQ_RESULT_TTL=3600

# ── DB connection pool (PostgreSQL / MariaDB only) ───────
DB_POOL_SIZE=3
DB_POOL_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── TrueLayer provider ───────────────────────────────────
TRUELAYER_CLIENT_ID=
TRUELAYER_CLIENT_SECRET=
TRUELAYER_REDIRECT_URI=https://localhost:3443/api/v1/providers/truelayer/callback
TRUELAYER_SANDBOX=true

# ── JSON provider ────────────────────────────────────────
JSON_PROVIDER_API_KEY=

# ── System notifier ──────────────────────────────────────
SYSTEM_NOTIFIER_ID=

# ── Email notifier (SMTP) ────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=manifold@example.com
SMTP_USE_TLS=true

# ── Slack notifier ───────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Telegram notifier ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── CORS / Frontend ──────────────────────────────────────
FRONTEND_URL=http://localhost:3000
